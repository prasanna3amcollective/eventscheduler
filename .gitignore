# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =============================================================================
# Dependencies
# =============================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
node_modules/

# =============================================================================
# Testing
# =============================================================================
/coverage

# =============================================================================
# Next.js
# =============================================================================
/.next/
.next/
out/

# =============================================================================
# Production / Build outputs
# =============================================================================
/build
build/
dist/

# =============================================================================
# Debug / Logs
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# Environment files
# =============================================================================
# (can opt-in for committing if needed)
.env*
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# =============================================================================
# Vercel
# =============================================================================
.vercel

# =============================================================================
# TypeScript
# =============================================================================
*.tsbuildinfo
next-env.d.ts
tsconfig.tsbuildinfo

# =============================================================================
# Prisma
# =============================================================================
# Generated client (migrations in prisma/migrations/ must be committed - do not ignore them)
/src/generated/prisma
src/generated/

# =============================================================================
# OS generated files
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# =============================================================================
# Editor / IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo

# =============================================================================
# Kilo / AI Agent config and artifacts
# =============================================================================
# Ignore only runtime/install artifacts and generated plans.
# Project config (commands/, agents/, skills/, workflows/, setup/run scripts, kilo.json) should be committed.
.kilo/node_modules/
.kilo/package.json
.kilo/package-lock.json
.kilo/pnpm-lock.yaml
.kilo/bun.lock
.kilo/yarn.lock
.kilo/plans/
.kilo/worktrees/
.kilo/agent-manager.json
.kilo/.gitignore
.kilo/
.kilo/plans

# =============================================================================
# Scratch / temporary files
# =============================================================================
scratch/

# =============================================================================
# Node.js
# =============================================================================
package-lock.json
internal/plans/

# AI Agent tools and generated folders
graphify-out/
.gemini/

