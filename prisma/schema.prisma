// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DetachReason {
  none
  edited
  cancelled
  rescheduled
  manually_created
}

enum RecurrenceTemplateType {
  activity
  responsibility
}

enum RecurrenceStatus {
  active
  archived
  draft
}

model Activity {
  id             String   @id @default(uuid()) // sys_id
  name           String
  startDateTime  DateTime
  endDateTime    DateTime
  duration       Int      // in minutes
  isRecurring    Boolean  @default(false)
  recurrenceRule String?
  recurrenceTemplateId    String?
  generatedFromTemplateId String?
  detachReason            DetachReason @default(none)

  category       String   @default("General")
  state          String   @default("Scheduled")
  participants   Participant[]

  recurrenceTemplate    RecurrenceTemplate? @relation("RecurrenceTemplate_Activities", fields: [recurrenceTemplateId], references: [id], onDelete: SetNull)
  generatedFromTemplate RecurrenceTemplate? @relation("RecurrenceTemplate_GeneratedFrom", fields: [generatedFromTemplateId], references: [id], onDelete: SetNull)

  // System Columns (ServiceNow Style)
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@unique([recurrenceTemplateId, startDateTime])
}

model Responsibility {
  id             String   @id @default(uuid()) // sys_id
  name           String
  startDateTime  DateTime
  endDateTime    DateTime
  duration       Int      // in minutes
  isRecurring    Boolean  @default(false)
  recurrenceRule String?
  recurrenceTemplateId    String?
  generatedFromTemplateId String?
  detachReason            DetachReason @default(none)

  category       String   @default("General")
  state          String   @default("Scheduled")
  owner          String?
  ownerId        String?

  recurrenceTemplate    RecurrenceTemplate? @relation("RecurrenceTemplate_Responsibilities", fields: [recurrenceTemplateId], references: [id], onDelete: SetNull)
  generatedFromTemplate RecurrenceTemplate? @relation("RecurrenceTemplate_GeneratedFrom_Resp", fields: [generatedFromTemplateId], references: [id], onDelete: SetNull)

  // System Columns (ServiceNow Style)
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@unique([recurrenceTemplateId, startDateTime])
}

model Participant {
  id         String   @id @default(uuid())
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  type       String   @default("Participant") // Leader, Guide, Observer, Participant
  attendance Int      @default(0) // 0=Present, 1=Half, 2=Absent
  payAsYouWish Float   @default(0)

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@unique([activityId, userId])
  @@map("participants")
}

model User {
  id       String @id @default(uuid())
  name     String
  username String @unique
  phone    String
  email    String @unique
  password String
  groups   UserGroupM2M[]
  roles    UserRole[]
  activities Participant[]

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@index([name])
}

model Group {
  id          String @id @default(uuid())
  name        String
  description String
  category    String
  users       UserGroupM2M[]
  roles       RoleGroupM2M[]

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt
}

model UserGroupM2M {
  id      String @id @default(uuid())
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@unique([userId, groupId])
  @@map("user_group_m2m")
}

model Role {
  id          String @id @default(uuid())
  name        String
  description String
  groups      RoleGroupM2M[]
  users       UserRole[]
  acls        AccessControlList[]

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt
}

model UserRole {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@unique([userId, roleId])
  @@map("user_role")
}

model RoleGroupM2M {
  id      String @id @default(uuid())
  role    Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId  String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@unique([roleId, groupId])
  @@map("role_group_m2m")
}

model AccessControlList {
  id          String @id @default(uuid())
  table       String
  operation   String // read, write, create, delete
  role        Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId      String
  description String?

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@map("sys_acl")
}

model RecurrenceTemplate {
  id                 String   @id @default(uuid())
  templateType       RecurrenceTemplateType @default(activity)
  name               String?
  recurrenceRule     String
  startDate          DateTime
  endDate            DateTime?
  excludeDates       DateTime[] @default([])
  lastGeneratedAt    DateTime?
  generatedUntil     DateTime?

  // Versioning
  versionSeriesId    String
  version            Int      @default(1)
  status             RecurrenceStatus @default(active)

  // System columns
  sys_created_by     String?
  sys_updated_by     String?
  sys_created_at     DateTime @default(now())
  sys_updated_at     DateTime @updatedAt

  // Reverse relations (populated when Activity/Responsibility rows reference this template via their FKs)
  activities                  Activity[]       @relation("RecurrenceTemplate_Activities")
  generatedFromActivities     Activity[]       @relation("RecurrenceTemplate_GeneratedFrom")
  responsibilities            Responsibility[] @relation("RecurrenceTemplate_Responsibilities")
  generatedFromResponsibilities Responsibility[] @relation("RecurrenceTemplate_GeneratedFrom_Resp")

  @@unique([versionSeriesId, version])
  @@index([templateType, versionSeriesId, status])
  @@index([templateType, generatedUntil, status])
  @@index([templateType, startDate, endDate])
  @@index([sys_created_at(sort: Desc)])
}
