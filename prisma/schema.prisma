// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Activity {
  id             String   @id @default(uuid()) // sys_id
  name           String
  startDateTime  DateTime
  endDateTime    DateTime
  duration       Int      // in minutes
  isRecurring    Boolean  @default(false)
  recurrenceRule String?
  category       String   @default("General")
  state          String   @default("Scheduled")
  participants   Participant[]

  // System Columns (ServiceNow Style)
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt
}

model Responsibility {
  id             String   @id @default(uuid()) // sys_id
  name           String
  startDateTime  DateTime
  endDateTime    DateTime
  duration       Int      // in minutes
  isRecurring    Boolean  @default(false)
  recurrenceRule String?

  // System Columns (ServiceNow Style)
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt
}

model Participant {
  id         String   @id @default(uuid())
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  type       String   @default("Participant") // Leader, Guide, Observer, Participant
  attendance Int      @default(0) // 0=Present, 1=Half, 2=Absent

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@unique([activityId, userId])
  @@map("participants")
}

model User {
  id       String @id @default(uuid())
  name     String
  username String @unique
  phone    String
  email    String @unique
  password String
  groups   UserGroupM2M[]
  roles    UserRole[]
  activities Participant[]

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt
}

model Group {
  id          String @id @default(uuid())
  name        String
  description String
  category    String
  users       UserGroupM2M[]
  roles       RoleGroupM2M[]

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt
}

model UserGroupM2M {
  id      String @id @default(uuid())
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@unique([userId, groupId])
  @@map("user_group_m2m")
}

model Role {
  id          String @id @default(uuid())
  name        String
  description String
  groups      RoleGroupM2M[]
  users       UserRole[]
  acls        AccessControlList[]

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt
}

model UserRole {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@unique([userId, roleId])
  @@map("user_role")
}

model RoleGroupM2M {
  id      String @id @default(uuid())
  role    Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId  String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@unique([roleId, groupId])
  @@map("role_group_m2m")
}

model AccessControlList {
  id          String @id @default(uuid())
  table       String
  operation   String // read, write, create, delete
  role        Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId      String
  description String?

  // System Columns
  sys_created_by String?
  sys_updated_by String?
  sys_created_at DateTime @default(now())
  sys_updated_at DateTime @updatedAt

  @@map("sys_acl")
}
